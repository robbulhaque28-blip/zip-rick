# ==========================================
# Zip-Rick Backend Environment Configuration
# ==========================================
# Copy this to .env and fill in your values

# --- Server ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zip_rick
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# --- Firebase ---
FIREBASE_PROJECT_ID=zip-rick-production
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@zip-rick-production.iam.gserviceaccount.com

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# --- AWS S3 ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=zip-rick-uploads
AWS_S3_BUCKET_DOCUMENTS=zip-rick-documents

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=30

# --- SMS/Notifications ---
SMS_PROVIDER=aws-sns
AWS_SNS_REGION=ap-south-1

# --- Logging ---
LOG_LEVEL=debug
LOG_DIR=./logs

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://admin.zip-rick.com

# --- Sentry (Error Tracking) ---
SENTRY_DSN=

# --- Registration Fee ---
PROMOTIONAL_REGISTRATION_FEE=499
STANDARD_REGISTRATION_FEE=999
PROMOTION_ACTIVE=true
